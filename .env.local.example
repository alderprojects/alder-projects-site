# =============================================================================
# Alder Projects — Read v1 staging env vars
# =============================================================================
# Copy to .env.local for local dev. Set the same vars on the staging Vercel
# project (read.alderprojects.com). Production uses different values; this
# file documents staging only.
#
# Anything marked (required) must be present for the staging site to boot.
# Anything marked (week N) is only used by code shipped in that week — safe
# to leave blank earlier.
# =============================================================================

# --- Postgres (required, week 1) ---
# Neon connection string. Use the *pooled* connection (-pooler) for
# DATABASE_URL and the *direct* connection for DIRECT_URL (Prisma migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/alder_read_v1?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/alder_read_v1?sslmode=require"

# --- Resend (required, week 1: magic links + catalog drift alerts) ---
RESEND_API_KEY="re_..."
ALERT_EMAIL="hello@alderprojects.com"
ALERT_FROM_EMAIL="alerts@alderprojects.com"
MAGIC_LINK_FROM_EMAIL="Alder Read <read@alderprojects.com>"

# --- Anthropic (required, week 1: vision eval; week 2: live extraction) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Amazon PA-API (required, week 1: catalog cron) ---
AMAZON_PAAPI_ACCESS_KEY=""
AMAZON_PAAPI_SECRET_KEY=""
AMAZON_PAAPI_ASSOCIATE_TAG="alderstaging-20"
AMAZON_PAAPI_REGION="us-east-1"

# --- Cron + flags ---
# Random 32+ char string. Vercel cron sends this as bearer token.
CRON_SECRET=""
# "true" weeks 1-2 (observe drift, don't write). Flip to "false" after week 2
# only if storage strategy + alerting noise is acceptable.
CATALOG_OBSERVE_ONLY="true"
# Cron kill switches — flip to "true" to disable individual crons without a
# redeploy. Useful when PA-API quota is shared, when the digest is noisy, or
# when GSC service account isn't set up yet.
DISABLE_CATALOG_CRON="false"
DISABLE_CATALOG_EXPAND_CRON="false"
DISABLE_DIGEST_EMAIL="false"
DISABLE_GSC_CRON="true"               # leave true until GSC service account set up (see below)
DISABLE_VISION_EXTRACT_CRON="false"   # the every-minute queue cron; stub through week 1

# --- Search Console (week 3+, optional; cron is disabled until configured) ---
# One-time setup (see docs/READ-V1-CODE-PROMPT.md or v731-bundle README):
#   1. Google Cloud Console → new project → enable "Google Search Console API"
#   2. Create service account "alder-gsc-reader", download JSON key
#   3. Paste full JSON contents (minified, single line) into GSC_SERVICE_ACCOUNT_JSON
#   4. In search.google.com/search-console → add service account email as
#      Property User with at least "restricted" access on alderprojects.com
#   5. Flip DISABLE_GSC_CRON=false
GSC_SITE_URL="https://alderprojects.com/"
GSC_SERVICE_ACCOUNT_JSON=""

# --- Vercel Blob (required, week 1: photo upload pipeline) ---
BLOB_READ_WRITE_TOKEN=""

# --- Base URL (required, week 1) ---
NEXT_PUBLIC_BASE_URL="https://read.alderprojects.com"
# Local dev:
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"
