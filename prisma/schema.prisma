// =============================================================================
// Alder Projects — Read v1 (v7.3.1) data graph schema
// =============================================================================
//
// Purpose: foundation for photo-aware Smart Cart, Alder Read, and the
// long-horizon acquisition asset (Zillow-primary, Angi-secondary).
//
// Design principles:
//   1. State-keyed from day one. Vermont is the first market; the schema
//      handles N states without refactor.
//   2. Event log is the source of truth. Relational tables are projections.
//   3. RoomSnapshots are immutable. The delta between snapshots is the
//      outcome signal that compounds.
//   4. valuation_delta is computed, not stored. Pipeline lives in code.
//   5. Photo extraction schema is forward-compatible with Tier 3 fields
//      (defects, products) — add fields, don't redesign.
//
// Migration: this replaces any prior schema. Run via:
//   npx prisma migrate dev --name read-v1-foundation
//
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled URL — used for runtime queries from serverless functions
  url       = env("DATABASE_URL")
  // Direct URL — required by Neon for migrations + introspection
  // (the pooler doesn't support all statement-level features Prisma needs)
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// IDENTITY LAYER
// =============================================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?
  displayName     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Auth
  sessions     Session[]
  magicLinks   MagicLink[]
  consents     Consent[]

  // Membership
  householdMembers HouseholdMember[]

  // Carts, projects, outcomes
  smartCarts SmartCart[]
  events     EventLog[] @relation("EventActor")

  @@index([email])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
  @@index([expiresAt])
}

model MagicLink {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  purpose    String // "signin" | "claim_anon_session"
  // Email snapshot (denormalized from User) — preserved on the link
  // so the v7.3.3-C claim flow can reference it after token consumption
  // even if the User row was later deleted/renamed.
  email      String?
  // Per-purpose payload for claim flow: {anonId, cartId, ...}. Empty
  // for ordinary signin links.
  payloadJson Json?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([purpose, expiresAt])
}

// =============================================================================
// HOUSEHOLD + PROPERTY LAYER
// =============================================================================

model Household {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    HouseholdMember[]
  properties Property[]
  projects   Project[]
}

model HouseholdMember {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  role        String    @default("owner") // "owner" | "member"
  joinedAt    DateTime  @default(now())

  @@unique([userId, householdId])
  @@index([householdId])
}

model Property {
  id                String    @id @default(cuid())
  householdId       String
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  nickname          String?
  // Normalized address fields — canonical lowercase, no punctuation
  addressLine1Norm  String
  addressLine2Norm  String?
  cityNorm          String
  state             String // "VT" | "NH" | "ME" — state-keyed from day one
  zip               String
  county            String?
  // Property facts
  yearBuilt         Int?
  yearBuiltEstimate Boolean   @default(false) // true = inferred, false = known
  sqftLiving        Int?
  lotSqft           Int?
  propertyType      String? // "single_family" | "condo" | "multi_family" | "other"
  // Baseline market value (from Zillow API, county assessor, etc.)
  valuationBaseline Int? // dollars
  valuationSourceAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  profiles        PropertyProfile[]
  rooms           Room[]
  projects        Project[]
  valuationDeltas ValuationDelta[]

  @@unique([addressLine1Norm, cityNorm, state, zip])
  @@index([state, zip])
  @@index([householdId])
}

model PropertyProfile {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  snapshotAt DateTime @default(now())
  // Full fetched profile — public records, GIS, climate, comps, rebate
  // eligibility, code tier, etc. JSON for flexibility; specific queries
  // pull fields out via Postgres JSON operators.
  profileJson Json
  // Versioning for the fetcher itself
  fetcherVersion String

  @@index([propertyId, snapshotAt])
}

// =============================================================================
// ROOM + PHOTO LAYER (the Zillow-primary moat)
// =============================================================================

model Room {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType     String // "kitchen" | "bathroom" | "living_room" | "bedroom" | "deck" | "basement" | "mudroom" | "exterior" | "other"
  name         String? // user-supplied nickname, e.g. "main bath"
  sqftEstimate Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  snapshots RoomSnapshot[]

  @@index([propertyId, roomType])
}

model RoomSnapshot {
  // Immutable. Each capture event creates a new RoomSnapshot.
  // The delta between RoomSnapshots is the outcome signal that
  // compounds the data asset's value over time.
  id                    String   @id @default(cuid())
  // roomId nullable from v7.3.3: anon-first photo upload happens before
  // a Room hierarchy is constructed (no Property anchor for a new
  // visitor). When the snapshot is anon-owned, roomId stays null and
  // roomType holds the room kind directly.
  roomId                String?
  room                  Room?    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  // Direct project link (v7.3.3) — anon flow attaches snapshot to a
  // Project without going through the Property -> Room hierarchy.
  projectId             String?
  project               Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Room type stored on the snapshot when there's no Room anchor
  // (anon flow). Mirrors Room.roomType.
  roomType              String?
  // Anonymous-visitor owner. Set during anon photo upload; cleared
  // once the visitor session is claimed by a User.
  visitorAnonId         String?
  snapshotAt            DateTime @default(now())
  // Capture context — "initial" before a project, "outcome" after,
  // "anon_photo_upload" for v7.3.3 anonymous photo reader flow.
  captureContext        String // "initial" | "outcome" | "periodic" | "pre_listing" | "anon_photo_upload"
  // Derived condition score (0-100). Computed from vision extractions on
  // photos belonging to this snapshot. Null until extractions complete.
  conditionScore        Int?
  // Finish era estimate (e.g. "1990s", "2010s"). Most-confident era across
  // photos in this snapshot.
  finishEra             String?
  // Inferred last renovation year, if any. Null = no inference.
  lastRenovatedEstimate Int?
  // Confidence in the snapshot-level fields above (0-1)
  confidence            Float?
  // Triggering event (e.g. Smart Cart purchase, Alder Read order, +60d email)
  triggeredByEventId    String?

  photos      Photo[]
  outcomesIn  Outcome[] @relation("OutcomeAfterSnapshot")

  @@index([roomId, snapshotAt])
  @@index([captureContext])
  @@index([projectId])
  @@index([visitorAnonId])
}

model Photo {
  id               String       @id @default(cuid())
  roomSnapshotId   String
  roomSnapshot     RoomSnapshot @relation(fields: [roomSnapshotId], references: [id], onDelete: Cascade)
  // Storage
  blobUrl          String // Vercel Blob signed URL or S3 path
  // v7.3.3-C-PR1.1: dropped global unique on blobKey. Two anon
  // visitors uploading the same content-addressed bytes are now
  // separate Photo rows. Same-anon re-upload of same bytes is
  // handled at the route layer (find-or-create on
  // (visitorAnonId, blobKey)).
  blobKey          String
  mimeType         String
  bytes            Int
  widthPx          Int?
  heightPx         Int?
  // Integrity + dedup
  perceptualHash   String // 64-bit pHash, hex-encoded
  exifStrippedAt   DateTime?
  // Confirms the blob write succeeded — set after Vercel Blob put()
  // returns a URL. Photo rows with null blobConfirmedAt are orphans
  // pending cleanup (anon cleanup cron sweeps them).
  blobConfirmedAt  DateTime?
  // Capture metadata (user-supplied at upload)
  captureMethod    String // "camera" | "library" | "import" | "web_upload"
  uploadedAt       DateTime     @default(now())
  // Consent flags at time of upload (snapshot of consent record)
  consentFlagsJson Json
  // Anonymous-visitor owner. Set during anon photo upload; cleared
  // once the visitor session is claimed by a User.
  visitorAnonId    String?
  // Soft delete (consent revocation)
  hiddenAt         DateTime?

  extractions VisionExtraction[]
  queueEntry  VisionExtractionQueue?

  @@index([roomSnapshotId])
  @@index([perceptualHash])
  @@index([visitorAnonId])
  @@index([blobConfirmedAt])
}

model VisionExtractionQueue {
  // Postgres-backed work queue for the vision extraction pipeline.
  // The every-minute Vercel cron at /api/cron/vision-extract claims
  // pending rows (FOR UPDATE SKIP LOCKED), runs extractFromPhoto,
  // writes the VisionExtraction row, and marks the queue entry
  // completed. Failed attempts increment `attempts` and reset to
  // pending until `attempts >= maxAttempts`, at which point the
  // entry transitions to "abandoned" and routes to manual review.
  //
  // photoId is @unique so enqueue is idempotent — re-uploading the
  // same photo (same content-addressed key) doesn't double-extract.
  //
  // Lifecycle:
  //   pending     enqueued, waiting for a worker
  //   processing  claimed by a worker (lockedAt + lockedBy set)
  //   completed   VisionExtraction row exists; success
  //   failed      last attempt errored; will retry up to maxAttempts
  //   abandoned   exceeded maxAttempts; manual triage
  id              String    @id @default(cuid())
  photoId         String    @unique
  photo           Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  status          String    @default("pending")
  priority        Int       @default(0) // higher = processed first; default 0 = FIFO by createdAt
  lockedAt        DateTime?
  lockedBy        String? // worker instance id (Vercel function id or hostname)
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3)
  lastAttemptAt   DateTime?
  lastError       String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, priority, createdAt]) // primary worker query
  @@index([status, lockedAt])            // stale-lock detection
}

model VisionExtraction {
  id              String    @id @default(cuid())
  photoId         String
  photo           Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  // Model + prompt versioning — re-extraction is allowed when the prompt
  // is improved; old extractions stay in the table for audit + replay.
  modelVersion    String // e.g. "claude-3-5-sonnet-vision-20241022"
  promptVersion   String // e.g. "v1.0.0"
  // Structured output — see lib/vision/extract.ts for schema. Tier 2 today,
  // Tier 3 fields (defects, products) added later without schema migration.
  extractionJson  Json
  overallConfidence Float
  // Manual review trail
  reviewStatus    String    @default("pending") // "pending" | "approved" | "corrected" | "rejected"
  reviewedById    String?
  reviewedAt      DateTime?
  reviewerNotes   String?
  correctedJson   Json? // if reviewStatus = "corrected", the human-corrected output
  // Cost accounting
  apiCostCents    Int?
  createdAt       DateTime  @default(now())

  @@index([photoId])
  @@index([reviewStatus, createdAt])
  @@index([overallConfidence])
}

// =============================================================================
// VALUATION DELTA (Zillow-primary derived field, computed nightly)
// =============================================================================

model ValuationDelta {
  // The headline derived field for the Zillow acquisition narrative.
  // Computed per property nightly from baseline + room snapshots + comps.
  // Stored as snapshots so the trajectory is queryable over time.
  id                     String   @id @default(cuid())
  propertyId             String
  property               Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  computedAt             DateTime @default(now())
  // The inputs
  baselineEstimateDollars Int // baseline market value at compute time
  baselineSource         String // "zillow_api" | "county_assessor" | "internal_comps"
  // Alder's adjusted estimate
  alderAdjustedDollars   Int
  // The delta
  deltaDollars           Int // alderAdjusted - baseline
  deltaPct               Float // delta / baseline
  // Model attribution
  modelVersion           String
  inputsHash             String // hash of all inputs, for cache + audit
  // Component contributions (per-room dollar attribution)
  attributionJson        Json
  confidence             Float

  @@index([propertyId, computedAt])
  @@index([inputsHash])
}

// =============================================================================
// PROJECT + LEAD LAYER (Angi-secondary)
// =============================================================================

model Project {
  id                String     @id @default(cuid())
  // householdId nullable from v7.3.3: anon-first photo upload creates
  // a Project before the visitor has any household anchor. Project gets
  // attached to a Household when the visitor claims by email (v7.3.3-C).
  householdId       String?
  household         Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  propertyId        String?
  property          Property?  @relation(fields: [propertyId], references: [id])
  topic             String // "kitchen" | "bathroom" | "outdoor" | "mudroom" | "weatherization" | "basement_moisture" | ...
  scopeVariant      String? // matches scope catalog in code
  // Anonymous-visitor owner. Set during anon photo upload; cleared
  // once the visitor session is claimed by a User (which assigns
  // householdId).
  visitorAnonId     String?
  // Project lane — DIY / handyman / small pro / contractor. The Angi-pitch field.
  lane              String? // "diy" | "handyman" | "small_pro" | "contractor" | "verify_first" | "hold"
  intentDepthScore  Float? // 0-1; how committed is the user to this project
  budgetBand        String? // "under_5k" | "5k_15k" | "15k_50k" | "50k_plus"
  timelineBand      String? // "now" | "3_months" | "6_12_months" | "exploring"
  status            String     @default("active") // "active" | "completed" | "abandoned"
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  smartCarts    SmartCart[]
  leadIntents   LeadIntent[]
  outcomes      Outcome[]
  roomSnapshots RoomSnapshot[]

  @@index([householdId, status])
  @@index([propertyId, status])
  @@index([topic, scopeVariant])
  @@index([visitorAnonId])
}

model SmartCart {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  // Anonymous-visitor owner. Set when the cart is synthesized from
  // anon photo upload; cleared on email claim.
  visitorAnonId String?
  // Pricing experiment cohort assignment (frozen at first impression).
  // Nullable from v7.3.3: the photo-reader beta has no pricing cohort
  // assignment until v7.3.7's A/B framework ships.
  priceCohort   String? // "free_with_photo" | "p9_99_with_photo" | "p29_no_photo_required"
  // Nullable from v7.3.3: anon-flow carts are unpurchased — pricePaidCents
  // is set only at Stripe webhook time when purchase completes.
  pricePaidCents Int?
  // Photo signal at time of cart synthesis
  photoCount    Int       @default(0)
  photoAttached Boolean   @default(false)
  // Output snapshot — the rendered cart at purchase time
  cartJson      Json
  // Dual-synthesis snapshots (v7.3.3): every photo-equipped cart is
  // synthesized twice — once without photo signal, once with — and both
  // payloads stored. photoChangedRecommendation captures whether the
  // photo signal flipped any item, tier, or lane. THIS IS THE KILL
  // METRIC for the photo-moat thesis: if <40% of carts show
  // photoChangedRecommendation=true by end of beta, the thesis fails.
  cartItemsJsonWithoutPhotos Json?
  cartItemsJsonWithPhotos    Json?
  photoChangedRecommendation Boolean?
  // Diff summary: {itemsAdded[], itemsRemoved[], tierShifts[], laneShifts[]}
  changeSummaryJson          Json?
  // Synthesis prompt version (so we can replay later)
  synthesisVersion String
  // Lifecycle
  status        String    @default("pending") // "pending" | "purchased" | "refunded"
  purchasedAt   DateTime?
  refundedAt    DateTime?
  refundReason  String?
  stripeChargeId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([status, purchasedAt])
  @@index([priceCohort, purchasedAt])
  @@index([visitorAnonId])
  @@index([photoChangedRecommendation])
}

model LeadIntent {
  id                 String    @id @default(cuid())
  projectId          String
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lane               String // matches Project.lane
  contractorFitScoreJson Json? // per-contractor fit scores at routing time
  status             String    @default("new") // "new" | "matched" | "accepted" | "declined" | "expired"
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  acceptances ContractorAcceptance[]

  @@index([projectId])
  @@index([lane, status])
}

model Contractor {
  // Slim contractor table. Full prospect/onboarding state stays in the
  // existing Google Sheets ContractorProspects/ContractorsDB; this is
  // the projection of approved contractors into the relational DB.
  id            String   @id @default(cuid())
  externalId    String?  @unique // PROS-####/CON-#### IDs from sheets
  businessName  String
  email         String
  phone         String?
  trades        String[] // ["painting", "electrical", ...]
  serviceAreas  String[] // ["chittenden_vt", "addison_vt", ...]
  state         String
  status        String   @default("approved") // "approved" | "paused" | "removed"
  leadTier      String? // "tier1" | "tier2" | "tier3" — pricing band
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  acceptances ContractorAcceptance[]

  @@index([state, status])
}

model ContractorAcceptance {
  id           String     @id @default(cuid())
  leadIntentId String
  leadIntent   LeadIntent @relation(fields: [leadIntentId], references: [id], onDelete: Cascade)
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  action       String // "previewed" | "accepted" | "declined" | "ignored"
  feePaidCents Int? // null if not accepted
  stripeChargeId String?
  actionAt     DateTime   @default(now())

  @@index([leadIntentId])
  @@index([contractorId, actionAt])
}

model Outcome {
  // The +60d after-photo capture event. Completes the Zillow valuation
  // story by linking project intent → action → before/after photos →
  // spend reality → revised valuation.
  id                     String        @id @default(cuid())
  projectId              String
  project                Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  afterPhotosSnapshotId  String?
  afterPhotosSnapshot    RoomSnapshot? @relation("OutcomeAfterSnapshot", fields: [afterPhotosSnapshotId], references: [id])
  completedAt            DateTime?
  spendActualCents       Int?
  contractorUsed         String?
  userReportedJson       Json? // free-form user notes
  createdAt              DateTime      @default(now())

  @@index([projectId])
}

// =============================================================================
// EVENT LOG (source of truth, append-only)
// =============================================================================

model EventLog {
  id           String   @id @default(cuid())
  // Event metadata
  eventType    String // see lib/events/types.ts for enum
  eventVersion String   @default("v1")
  occurredAt   DateTime @default(now())
  // Actor
  actorId      String? // userId if signed in
  actor        User?    @relation("EventActor", fields: [actorId], references: [id])
  anonId       String? // VisitorSession.anonId if not signed in
  // Subject — the entity the event acted upon
  subjectType  String? // "Property" | "SmartCart" | "Photo" | "Project" | ...
  subjectId    String?
  // Payload — typed per eventType (see lib/events/types.ts)
  payloadJson  Json
  // Context
  sessionId    String?
  source       String? // "web" | "email" | "admin" | "system" | "cron"

  @@index([eventType, occurredAt])
  @@index([actorId, occurredAt])
  @@index([anonId, occurredAt])
  @@index([subjectType, subjectId])
  // Standalone time index — existing composites all lead with another
  // column, so they can't serve "all events in last X" queries efficiently.
  @@index([occurredAt])
}

// =============================================================================
// CONSENT (granular, per-purpose, versioned)
// =============================================================================

model Consent {
  id        String    @id @default(cuid())
  // userId nullable from v7.3.3: anon-first photo upload records consent
  // against an anonId before any User exists. On email claim, consent
  // rows are reassigned to the User (and the corresponding userId/anonId
  // pair becomes uniquely indexed at most one way).
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Anonymous-visitor owner (mutually exclusive with userId — enforced
  // by raw-SQL CHECK constraint added in the migration).
  anonId    String?
  // Purpose — what is the data used for
  purpose   String // "personal_recommendations" | "product_improvement" | "valuation_research" | "public_content_use" | "marketing"
  dataType  String // "photos" | "address" | "smart_cart_history" | "behavioral" | "photo"
  granted   Boolean
  version   String? // e.g. "v1.0.0" — privacy policy version at time of consent (nullable for anon rows where version is captured per-session)
  grantedAt DateTime  @default(now())
  revokedAt DateTime?
  source    String // "signup" | "settings" | "modal_inline" | "anon_upload"

  // Partial unique indexes for the two ownership modes are declared in
  // the migration SQL (Prisma's @@unique doesn't support WHERE clauses).
  // Likewise the "userId IS NOT NULL OR anonId IS NOT NULL" CHECK.
  @@index([userId])
  @@index([anonId])
}

// =============================================================================
// CATALOG (Smart Cart universe — price refresh tracking)
// =============================================================================

model CatalogProduct {
  // Optional projection of the Smart Cart universe into the DB.
  // For weeks 1-12, the universe stays in source (src/content/smart-cart/
  // universe.ts) and this table is unused. Migrate to DB-backed when the
  // universe exceeds ~1,000 SKUs and source file management is too heavy.
  universeId        String    @id
  productName       String
  amazonAsin        String?   @unique
  affiliateUrl      String
  priceLow          Float
  priceHigh         Float
  tier              String // "budget" | "sweet_spot" | "premium"
  availability      String    @default("in_stock") // "in_stock" | "limited" | "out_of_stock" | "unknown"
  unavailableReason String?
  tagsJson          Json
  lastRefreshedAt   DateTime?
  updatedAt         DateTime  @updatedAt

  snapshots CatalogPriceSnapshot[]

  @@index([availability])
  @@index([tier, availability])
}

model CatalogPriceSnapshot {
  // Append-only price history per refresh run. Used for:
  //   1. Audit when a buyer disputes a quoted price
  //   2. Future "price has dropped" email nudges
  //   3. Drift analysis over time
  //   4. Catalog quality metrics (uptime, stability)
  id           String   @id @default(cuid())
  universeId   String
  product      CatalogProduct? @relation(fields: [universeId], references: [universeId])
  asin         String
  priceLow     Float
  priceHigh    Float
  availability String
  capturedAt   DateTime @default(now())

  @@index([universeId, capturedAt])
  @@index([asin, capturedAt])
}

// =============================================================================
// VISITOR SESSION (pre-signin signal capture)
// =============================================================================

model VisitorSession {
  id         String   @id @default(cuid())
  anonId     String   @unique
  // All signals captured pre-signin — topic interest, scope variant probed,
  // calculator inputs, chat snippets, etc. JSON for flexibility.
  signalsJson Json
  // First touch attribution
  firstSource String? // "organic" | "direct" | "pinterest" | "reddit" | ...
  firstUtm   Json?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  // If/when claimed by a signed-in user
  claimedByUserId String?
  claimedAt       DateTime?

  @@index([anonId])
  @@index([claimedByUserId])
}

// =============================================================================
// EXPANSION LAYER (Job 2 — catalog expansion + review + GSC feedback)
// =============================================================================
// Added in the v7.3.1 expansion bundle. Five new models that ride on top of
// the foundation schema:
//
//   CatalogExpansionCandidate  LLM-proposed catalog additions with Google-
//                              aligned commodity-risk + evidence gates
//   RecommendationChange       Refresh-cron-flagged changes for the review
//                              queue (distinct from CatalogPriceSnapshot
//                              which stays append-only history)
//   ReviewActionToken          Signed single-use tokens for one-click email
//                              approve/reject/supply_evidence
//   GscPageStats               Search Console weekly snapshot with the
//                              aiOverviewLikely inferred signal
//   PhotoContentUse            Per-photo opt-in for public SEO content use
//                              (separate, higher-bar consent from personal
//                              recommendations). Linked to Photo by photoId
//                              in application code, not FK — keeps the
//                              consent layer decoupled from the data layer.
// =============================================================================

model CatalogExpansionCandidate {
  // States:
  //   draft           created by expansion cron
  //   pending_review  in the 5 AM digest, awaiting admin action
  //   needs_evidence  approved but commodity-risk requires evidence pre-publish
  //   approved        evidence supplied (if needed), publish-ready
  //   published       wired into live universe / scope catalog
  //   rejected        killed by admin, kept for audit
  //   ignored         no action; auto-expires after 30 days
  id                    String    @id @default(cuid())
  scopeId               String
  candidateType         String // "product" | "skip_item" | "route_out" | "new_scope" | "guide_section"
  title                 String
  rationale             String
  proposedSlot          String?
  proposedTier          String?
  proposedAffiliateUrl  String?
  proposedPriceRange    String?
  commodityRiskScore    Int // 0-100; higher = more commodity-like
  evidenceNeededJson    Json
  evidenceSuppliedJson  Json?
  uniqueAngle           String?
  llmModelVersion       String
  llmPromptVersion      String
  estimatedBuyerValue   String?
  riskLevelJson         Json
  status                String    @default("draft")
  reviewedById          String?
  reviewedAt            DateTime?
  reviewerNotes         String?
  publishedAt           DateTime?
  publishedAsJson       Json?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  actionTokens ReviewActionToken[]

  @@index([status, createdAt])
  @@index([scopeId, status])
  @@index([commodityRiskScore])
}

model RecommendationChange {
  // Distinct from CatalogPriceSnapshot — that's append-only history of every
  // refresh; this is the actionable review queue (rows that need admin eyes).
  id              String    @id @default(cuid())
  universeId      String
  productName     String
  asin            String?
  changeType      String // "price_jump" | "price_drop" | "unavailable" | "asin_not_found" | "url_redirect"
  oldValue        String
  newValue        String
  pctChange       Float?
  riskTier        String // "auto_safe" | "needs_review" | "never_auto"
  status          String    @default("pending_review") // "pending_review" | "approved" | "rejected" | "auto_published" | "ignored"
  reviewedById    String?
  reviewedAt      DateTime?
  reviewerNotes   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  actionTokens ReviewActionToken[]

  @@index([status, createdAt])
  @@index([universeId])
  @@index([riskTier, status])
}

model ReviewActionToken {
  // 32-byte random hex token, single-use, 7-day expiry. Bound to
  // (subject_id, action) — token for "approve candidate X" cannot be used
  // to approve candidate Y. No login required; the token IS the auth.
  id              String    @id @default(cuid())
  token           String    @unique
  action          String // "approve" | "reject" | "approve_low_confidence" | "supply_evidence"
  candidateId     String?
  candidate       CatalogExpansionCandidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  changeId        String?
  change          RecommendationChange?      @relation(fields: [changeId], references: [id], onDelete: Cascade)
  issuedAt        DateTime  @default(now())
  expiresAt       DateTime
  consumedAt      DateTime?
  consumedFromIp  String?

  @@index([token])
  @@index([expiresAt])
  @@index([candidateId])
  @@index([changeId])
}

model GscPageStats {
  // GSC doesn't expose an AI Overview field. We infer:
  //   rising impressions AND falling CTR → being summarized in AI Overviews
  id                       String   @id @default(cuid())
  pageUrl                  String
  windowStart              DateTime
  windowEnd                DateTime
  impressions              Int
  clicks                   Int
  ctr                      Float
  avgPosition              Float
  topQueriesJson           Json
  aiOverviewLikely         Boolean  @default(false)
  publishedFromCandidateId String?
  createdAt                DateTime @default(now())

  @@unique([pageUrl, windowStart])
  @@index([windowStart])
  @@index([publishedFromCandidateId])
}

// =============================================================================
// HANDOFF TOKENS (v7.3.3-B1: desktop -> mobile QR handoff)
// =============================================================================
//
// Lets a desktop visitor scan a QR code on their phone, redeem a token,
// and continue under the same alder_anon_id cookie on mobile. The token
// is single-use + 5-min TTL. anonId is the visitor's id being handed off.

model HandoffToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique // SHA-256 hash of the raw token (raw token never stored)
  anonId         String // the visitor session being handed off
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?
  consumedFromIp String?

  @@index([anonId])
  @@index([expiresAt])
}

model PhotoContentUse {
  // Public SEO use consent — higher bar than personal_recommendations.
  id               String    @id @default(cuid())
  photoId          String    @unique
  granted          Boolean
  grantedAt        DateTime  @default(now())
  revokedAt        DateTime?
  allowGuides      Boolean   @default(true)
  allowOutcomes    Boolean   @default(true)
  allowMarketing   Boolean   @default(false) // ads/social — separate higher bar
  attributionStyle String    @default("anonymous") // "anonymous" | "first_name_only" | "full_name"
  consentVersion   String
  source           String // "smart_cart_modal" | "outcome_email" | "settings_page"

  @@index([granted, allowGuides])
  @@index([granted, allowOutcomes])
}

