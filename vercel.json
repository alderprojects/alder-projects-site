{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    { "path": "/api/cron/catalog-refresh", "schedule": "17 8 * * *" },
    { "path": "/api/cron/catalog-expand", "schedule": "47 8 * * *" },
    { "path": "/api/cron/daily-digest", "schedule": "0 10 * * *" },
    { "path": "/api/cron/gsc-sync", "schedule": "17 9 * * 1" },
    { "path": "/api/cron/anon-cleanup", "schedule": "0 5 * * *" }
  ]
}
