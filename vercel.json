{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    { "path": "/api/cron/catalog-refresh", "schedule": "0 11,23 * * *" },
    { "path": "/api/cron/user-data-sync", "schedule": "0 7 * * *" },
    { "path": "/api/cron/outcome-capture", "schedule": "0 8 * * *" },
    { "path": "/api/cron/valuation-delta", "schedule": "0 9 * * *" }
  ]
}
